{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "properties": {
    "script": {
      "type": "string",
      "description": "Путь к файлу Ballerina (.bal) или директории пакета для запуска."
    },
    "scriptArguments": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "description": "Аргументы командной строки, передаваемые программе Ballerina."
    },
    "commandOptions": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "description": "Опции сборки/запуска для команды `bal run` (например, `--offline`)."
    },
    "debuggeePort": {
      "type": "integer",
      "description": "Порт отладки программы.",
      "default": 5005
    },
    "networkLogs": {
      "type": "boolean",
      "description": "Включить ли логирование сетевых пакетов.",
      "default": false
    }
  }
}
